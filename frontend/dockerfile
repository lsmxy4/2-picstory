# 프로덕션 이미지: Vite 빌드 + nginx 정적 서빙 (Docker Hub 푸시용)
FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# 브라우저가 API 서버를 호출할 베이스 URL (빌드 시 고정)
ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL}

ARG VITE_KAKAO_LOGIN_URL
ENV VITE_KAKAO_LOGIN_URL=${VITE_KAKAO_LOGIN_URL}

# 카카오 OAuth 인증 URL을 프론트에서 직접 만들 때 사용합니다.
ARG VITE_KAKAO_REST_API_KEY
ENV VITE_KAKAO_REST_API_KEY=${VITE_KAKAO_REST_API_KEY}
ARG VITE_KAKAO_REDIRECT_URI
ENV VITE_KAKAO_REDIRECT_URI=${VITE_KAKAO_REDIRECT_URI}
ARG VITE_KAKAO_LOGIN_URL
ENV VITE_KAKAO_LOGIN_URL=${VITE_KAKAO_LOGIN_URL}

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
